# MySQL
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=rag_chat
MYSQL_USER=rag_user
MYSQL_PASSWORD=change_this_app_password

# Backend security
APP_SECURITY_JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
APP_SECURITY_JWT_EXPIRATION_MINUTES=120

# OpenAI
# Required for document embeddings and chat answers.
OPENAI_API_KEY=sk-your-openai-api-key

# Optional proxy settings
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=localhost,127.0.0.1,backend,mysql,rag-mysql

